{
  "name": "devland-workspace",
  "private": true,
  "scripts": {
    "dev": "bun run --cwd devland-app dev",
    "dev:app": "bun run --cwd devland-app dev",
    "dev:extension:gh-prs": "bun run --cwd extensions/gh-prs dev",
    "install:app": "bun install --cwd devland-app",
    "install:extension:gh-prs": "bun install --cwd extensions/gh-prs",
    "typecheck": "bun run --cwd devland-app typecheck",
    "lint": "bun run --cwd devland-app lint",
    "test": "bun run --cwd devland-app test"
  }
}
